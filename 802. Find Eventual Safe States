class Solution {
    private:
vector<int> bfs(vector<int>&ind,vector<vector<int>>&revgraph,vector<int>&ans){
        queue<int>q;
     for(int i =0;i<ind.size();i++){
        if(!ind[i]){
            q.push(i);
        }
     }
     while(!q.empty()){
        int node = q.front();
        ans.push_back(node);
        q.pop();
        for(int adjNode: revgraph[node]){
            ind[adjNode]--;
            if(!ind[adjNode]){
                q.push(adjNode);
            }
        }
     }
     
     return ans;
    }
public:
    vector<int> eventualSafeNodes(vector<vector<int>>& graph) {
        int V = graph.size();
        vector<int>ans;
       vector<vector<int>>revgraph(V);
              vector<int>indegree(V); 
       for(int i=0;i<V;i++){
       for(int j =0; j<graph[i].size();j++){
        indegree[i]++;
        revgraph[graph[i][j]].push_back(i);
       }
       }
bfs(indegree,revgraph,ans);
sort(ans.begin(),ans.end());
      return  ans;
    }
};
